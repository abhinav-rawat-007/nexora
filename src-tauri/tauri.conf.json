{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexora",
  "version": "0.1.0",
  "identifier": "app.nexora.hub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexora",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "fullscreen": true,
        "decorations": false,
        "resizable": true,
        "backgroundColor": "#05070b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
